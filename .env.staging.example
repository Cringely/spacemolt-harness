# Non-secret only, per security-baseline.md. Copy to .env before running
# docker-compose.staging.yml. This is the validation deploy on the staging
# host — no reverse proxy or SSO provider is in play here, so the dashboard
# is published directly on the staging host's LAN IP for a browser check.
HARNESS_IMAGE_TAG=
# LAN IP of the staging host itself (never 0.0.0.0 — bind to one interface).
STAGING_BIND_IP=
# MUST equal agents.yaml's dashboard_port (default 8642).
HARNESS_DASHBOARD_PORT=8642
# REMINDER (not read by the app): agents.yaml must set
# dashboard_host: 0.0.0.0 for this container deploy. The code default
# (127.0.0.1) binds to the container's own loopback only -- the published
# port above would connect to nothing, while the in-container healthcheck
# (which also hits 127.0.0.1) would still report healthy. Silent failure
# mode -- see docker-compose.staging.yml.
