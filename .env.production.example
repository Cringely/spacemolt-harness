# Non-secret only, per security-baseline.md — passwords/tokens live under
# ${SECRETSDIR}, never here. Copy to .env on the production host before running
# docker-compose.production.yml. Values follow the host's existing reverse-proxy
# stack conventions — match them rather than inventing new ones.
HARNESS_IMAGE_TAG=
DOMAIN1=example.com
SECRETSDIR=
# MUST equal agents.yaml's dashboard_port (default 8642) — the app reads
# only agents.yaml for its listen port; this value feeds the reverse-proxy
# service label and the Dockerfile's HEALTHCHECK.
HARNESS_DASHBOARD_PORT=8642
# REMINDER (not read by the app): agents.yaml must set
# dashboard_host: 0.0.0.0 for this container deploy. The code default
# (127.0.0.1) binds to the container's own loopback only -- the reverse proxy
# reaching over the `front` network would connect to nothing, while the
# in-container healthcheck (which also hits 127.0.0.1) would still report
# healthy. Silent failure mode -- see docker-compose.production.yml.
